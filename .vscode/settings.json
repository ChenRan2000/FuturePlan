{
  // 全局缩放（保持默认1.0，不拉伸界面）
  "window.zoomLevel": 1.0,

  // 编辑器：恢复默认字体 + 统一大小
  "editor.fontFamily": "JetBrains Mono, 'Microsoft YaHei', monospace",
  "editor.fontSize": 15,       // 统一大小（14/16/18 任选）
  "editor.lineHeight": 1.6,    // 行高，让文字更舒展

  // 终端：恢复默认字体 + 和编辑器同大小
  "terminal.integrated.fontFamily": "JetBrains Mono, 'Microsoft YaHei', monospace",
  "terminal.integrated.fontSize": 15,  // 和编辑器完全一致

  // 关闭自定义字体覆盖，强制用默认
  "editor.fontLigatures": false,
  "terminal.integrated.fontLigatures": false
}